{
  "name": "MMDManager",
  "version": "0.1.0",
  "description": "MMDManager",
  "author": "guozihang",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win --publish always"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.gzhlaker.mmdmanager",
    "productName": "MMDManager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "css/**/*",
      "js/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}
